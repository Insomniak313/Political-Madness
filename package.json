{
  "name": "political-madness",
  "version": "1.0.0",
  "description": "Jeu de débat politique avec IA",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -s first -n web,api -c green,cyan \"npm run dev:client\" \"npm run server\"",
    "dev:client": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "server": "tsx watch server/index.ts",
    "server:start": "node dist-server/index.js",
    "server:build": "tsc -p tsconfig.server.json"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "openai": "^6.2.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "tsx": "^4.19.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.11"
  }
}
