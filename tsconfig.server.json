{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist-server",
    "module": "ESNext",
    "target": "ES2020",
    "moduleResolution": "bundler",
    "rootDir": "./",
    "noEmit": false,
    "resolveJsonModule": true,
    "types": ["node"],
    "skipLibCheck": true,
    "allowImportingTsExtensions": false
  },
  "include": ["server/**/*.ts"],
  "exclude": ["node_modules", "dist", "dist-server"]
}
